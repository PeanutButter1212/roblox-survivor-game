--!strict
-- Stages.luau
-- Per-stage definitions. Each player progresses through these independently. The first
-- few are hand-tuned; beyond the list, stages are generated by scaling the last one so
-- progression is effectively endless ("the next stage" always exists).

export type StageConfig = {
	number: number,
	name: string,
	arenaSize: number, -- floor is arenaSize x arenaSize studs
	duration: number, -- seconds to survive
	enemyHealth: number,
	enemySpeed: number,
	contactDamage: number,
	startMaxAlive: number, -- live-enemy cap at stage start
	endMaxAlive: number, -- live-enemy cap at stage end
	startSpawnInterval: number, -- seconds between spawns at start
	endSpawnInterval: number, -- seconds between spawns at end
}

local Stages = {}

-- Hand-authored opening stages.
Stages.List = {
	{
		name = "Stage 1",
		arenaSize = 300,
		duration = 120,
		enemyHealth = 18,
		enemySpeed = 8,
		contactDamage = 7,
		startMaxAlive = 12,
		endMaxAlive = 45,
		startSpawnInterval = 1.3,
		endSpawnInterval = 0.5,
	},
	{
		name = "Stage 2",
		arenaSize = 340,
		duration = 150,
		enemyHealth = 26,
		enemySpeed = 9,
		contactDamage = 9,
		startMaxAlive = 16,
		endMaxAlive = 60,
		startSpawnInterval = 1.1,
		endSpawnInterval = 0.4,
	},
	{
		name = "Stage 3",
		arenaSize = 380,
		duration = 180,
		enemyHealth = 36,
		enemySpeed = 10,
		contactDamage = 11,
		startMaxAlive = 20,
		endMaxAlive = 80,
		startSpawnInterval = 1.0,
		endSpawnInterval = 0.32,
	},
}

-- Builds a scaled stage beyond the authored list by compounding the last entry.
local function generateBeyond(number: number): StageConfig
	local last = Stages.List[#Stages.List]
	local steps = number - #Stages.List
	local growth = 1.25 ^ steps
	return {
		number = number,
		name = "Stage " .. number,
		arenaSize = math.min(520, last.arenaSize + steps * 15),
		duration = last.duration + steps * 15,
		enemyHealth = math.floor(last.enemyHealth * growth),
		enemySpeed = math.min(16, last.enemySpeed + steps),
		contactDamage = math.floor(last.contactDamage * (1.1 ^ steps)),
		startMaxAlive = math.floor(last.startMaxAlive * growth),
		endMaxAlive = math.floor(last.endMaxAlive * growth),
		startSpawnInterval = math.max(0.2, last.startSpawnInterval - steps * 0.05),
		endSpawnInterval = math.max(0.12, last.endSpawnInterval - steps * 0.02),
	}
end

-- Returns the config for stage `number` (1-based). Authored stages come straight from
-- the list; anything beyond is generated.
function Stages.get(number: number): StageConfig
	if number < 1 then
		number = 1
	end
	if number <= #Stages.List then
		local config = table.clone(Stages.List[number])
		config.number = number
		config.name = config.name or ("Stage " .. number)
		return config
	end
	return generateBeyond(number)
end

return Stages
